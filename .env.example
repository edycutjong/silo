# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Silo — Environment Variables Example                                       ║
# ║                                                                            ║
# ║  WHICH FILE TO USE:                                                        ║
# ║  ─────────────────                                                         ║
# ║  • Local development  →  .env          (gitignored, loaded automatically)  ║
# ║  • Production         →  Set via Platform Dashboard (e.g. Vercel/CloudRun) ║
# ║                                                                            ║
# ║  SETUP:                                                                    ║
# ║  ──────                                                                    ║
# ║  1. Copy this file:   cp .env.example .env                                 ║
# ║  2. Fill in the values below.                                              ║
# ║  3. NEVER commit the active .env file — it is gitignored.                  ║
# ║                                                                            ║
# ║  NEXT.JS CONVENTION:                                                       ║
# ║  ───────────────────                                                       ║
# ║  Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.          ║
# ║  All other variables are server-side only (agent, scripts, contract).      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ════════════════════════════════════════════════════════════════════════════════
#  ACTIVE — read by the running code. The local demo needs only these.
# ════════════════════════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Identity (Tenant DID)                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Terminal 3 Tenant DID (decentralized identifier).
# Format: did:t3n:<40-char hex>
# Read by: agent  →  agent/src/lib/db.ts:50, agent/src/lib/wasmRunner.ts:113 (falls back to did:t3n:whistleblower123)
DID=did:t3n:0123456789abcdef0123456789abcdef01234567

# Same DID but exposed to the browser for the Next.js UI dashboard header.
# ⚠️  Must be a did:t3n:… value — NOT your API key.
# Read by: ui     →  ui/src/app/page.tsx:196 (falls back to did:t3n:whistleblower123)
NEXT_PUBLIC_T3N_DID=did:t3n:0123456789abcdef0123456789abcdef01234567


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Coordinator Agent Configurations                                            │
# └──────────────────────────────────────────────────────────────────────────────┘

# Port the Express coordinator agent listens on.
# Read by: agent  →  agent/src/index.ts:7 (falls back to 3001)
PORT=3001

# Coordinator Agent URL as seen by the browser dashboard.
# Leave commented for a purely local run (it defaults to http://localhost:3001).
# Read by: ui     →  ui/src/app/page.tsx:23
# NEXT_PUBLIC_AGENT_URL=http://localhost:3001


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Production Terminal 3 ADK Configurations (Enclave Deployments)              │
# └──────────────────────────────────────────────────────────────────────────────┘

# Your Terminal 3 API Key (64-char hex string, starts with 0x).
# RESERVED — used in production only; NOT read by local code. Keep commented locally.
# T3N_API_KEY=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Terminal 3 Sandbox URL (the TEE enclave host endpoint).
# RESERVED — used in production integrations only; NOT read by local code.
# ENCLAVE_URL=https://sandbox.terminal3.io


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Local Development Mock/Fallback Configs                                     │
# └──────────────────────────────────────────────────────────────────────────────┘

# Mock OTP codes allowed for local/testing verification (comma-separated).
# ⚠️  These backdoor codes AND the debugOtp echo are ONLY honored when
#     NODE_ENV !== "production". Set NODE_ENV=production to disable both.
# Read by: agent  →  agent/src/lib/wasmRunner.ts (host_otp_verify, non-prod only)
MOCK_OTP_CODES=883391,000000

# Default profile settings used for the whistleblower mockup.
# Read by: agent  →  agent/src/lib/db.ts, agent/src/lib/wasmRunner.ts
DEFAULT_PROFILE_FIRST_NAME=Anonymous
DEFAULT_PROFILE_EMAIL=whistleblower@hospital-safety.org


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Security Hardening (set these in production)                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# Allowed browser origin(s) for the coordinator API (comma-separated).
# Restricts CORS so arbitrary sites cannot drive-by call the agent.
# Read by: agent  →  agent/src/app.ts (falls back to http://localhost:3000)
# CORS_ORIGIN=http://localhost:3000

# Bearer token guarding sensitive admin/seed routes (reset, download, profile seed).
# If unset (local demo) these routes are open; set a strong value in production.
# Read by: agent  →  agent/src/app.ts (requireAdmin middleware)
# ADMIN_TOKEN=

# Pin the enclave's Ed25519 signing key (PKCS8 PEM) so issued manifest VCs stay
# verifiable across restarts. If unset, an ephemeral key is generated per process.
# Read by: agent  →  agent/src/lib/wasmRunner.ts (getEnclaveKeys)
# SILO_ENCLAVE_PRIVATE_KEY=

# Set to "production" to disable the debug OTP echo and mock backdoor OTP codes.
# NODE_ENV=production

