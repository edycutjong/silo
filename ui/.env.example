# Silo UI — local env example. Copy this to .env.local for local Next.js runs.
# Only NEXT_PUBLIC_* values are exposed to the browser.
#
# NOTE: the DID is a functional join key — the coordinator agent looks up its seeded
# profile DB by this value (db.ts / wasmRunner.ts, keyed on did:t3n:whistleblower123).
# Keep the persona DID here so the UI ↔ agent ↔ seed data stay consistent. Do NOT put
# the raw tenant DID here or the demo profile lookup desyncs.
NEXT_PUBLIC_T3N_DID=did:t3n:f600f352f618561182968a3507ac40d05365a4b2

# Coordinator agent URL. Default http://localhost:3001 works for a local run.
# NEXT_PUBLIC_AGENT_URL=http://localhost:3001
