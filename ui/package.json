{
  "name": "silo-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --silent",
    "test:coverage": "jest --silent --coverage",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "ci:full": "npm run ci && npm run build && npm run e2e",
    "seed": "python3 scripts/seed.py",
    "e2e": "playwright test",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "lucide-react": "^1.21.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}